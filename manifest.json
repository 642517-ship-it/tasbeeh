function dayOfYear() {
  const now = new Date();
  const start = new Date(now.getFullYear(), 0, 0);
  const diff = now - start;
  return Math.floor(diff / (1000*60*60*24));
}

function getTodaysDua() {
  return DAILY_DUAS[dayOfYear() % DAILY_DUAS.length];
}

// ════════════════════════════════════════════════════════════════════
// Render the HOME screen
// ════════════════════════════════════════════════════════════════════
function renderHome() {
  const now = new Date();
  const dayName = ARABIC_DAYS[now.getDay()];
  const hijri = getHijriDate();
  const gregDay = toArDigits(now.getDate());
  const gregMonth = ARABIC_MONTHS_GREG[now.getMonth()];
  const gregYear = toArDigits(now.getFullYear());

  document.getElementById('hijri-day').textContent = dayName;
  document.getElementById('hijri-date').textContent =
    `${toArDigits(hijri.day)} ${hijri.monthName} ${toArDigits(hijri.year)} هـ`;
  document.getElementById('greg-date').textContent =
    `${gregDay} ${gregMonth} ${gregYear} م`;

  const dua = getTodaysDua();
  document.getElementById('dua-title').textContent = dua.title;
  document.getElementById('dua-text').textContent = dua.text;

  document.getElementById('home-today').textContent = state.todayTotal.toLocaleString('ar-SA');
  document.getElementById('home-permanent').textContent = state.permanentTotal.toLocaleString('ar-SA');
}

// ════════════════════════════════════════════════════════════════════
// Toggle session type (tasbeeh ↔ salah) — preserves both progress
// ════════════════════════════════════════════════════════════════════
function toggleSessionType() {
  const btn = document.getElementById('session-toggle');
  btn.classList.add('swapping');
  setTimeout(() => btn.classList.remove('swapping'), 400);

  state.sessionType = (state.sessionType === 'tasbeeh') ? 'salah' : 'tasbeeh';
  ss('sessionType', state.sessionType);
  updateUI();
}


// ======= SCREEN MANAGEMENT =======
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  const target = document.getElementById(id);
  if (target) target.classList.add('active');

  // Sync ALL nav buttons across all screens
  document.querySelectorAll('.nav-btn').forEach(btn => btn.classList.remove('active'));
  const activeIdMap = {
    'home':           ['nav-home','nav-home1','nav-home2','nav-home3'],
    'main':           ['nav-tasbeeh','nav-main','nav-main2','nav-main3'],
    'stats':          ['nav-stats0','nav-stats','nav-stats2','nav-stats3'],
    'settings-screen':['nav-settings0','nav-settings','nav-settings2','nav-settings3']
  };
  (activeIdMap[id] || []).forEach(navId => {
    const el = document.getElementById(navId);
    if (el) el.classList.add('active');
  });

  if (id === 'home')            renderHome();
  if (id === 'main')            updateUI();
  if (id === 'stats')           renderStats();
  if (id === 'settings-screen') renderSettings();
}

// ======= MAIN COUNTER LOGIC =======
function getDhikr() {
  if (state.sessionType === 'salah') return SALAH;
  // Show the dhikr corresponding to the next tap based on tasbeehCounter.
  // Counter 0 → سبحان الله, after 1 tap counter=1 → الحمد لله, etc.
  const c = state.tasbeehCounter;
  const idx = c === 0 ? 0 : ((c) % TASBEEH.length);
  return TASBEEH[idx];
}

function updateUI() {
  const dhikr = getDhikr();
  document.getElementById('current-dhikr').textContent = dhikr.text;
  document.getElementById('dhikr-type-label').textContent = dhikr.label || '';

  // Toggle button label shows current mode and indicates tap to switch
  const isTasbeeh = state.sessionType === 'tasbeeh';
  const labelEl = document.getElementById('session-label');
  if (labelEl) {
    labelEl.textContent = isTasbeeh
      ? 'جلسة التسابيح'
      : 'الصلاة على النبي ﷺ';
  }

  const counter = getCounter();
  document.getElementById('counter-display').textContent = counter;
  document.getElementById('today-total').textContent = state.todayTotal.toLocaleString('ar-SA');
  document.getElementById('grand-total').textContent = state.permanentTotal.toLocaleString('ar-SA');
  document.getElementById('session-num').textContent = state.sessionNum;

  // Progress arc: circumference = 2πr = 2*π*85 ≈ 534
  const circumference = 534;
  const progress = Math.min(counter / state.target, 1);
  const offset = circumference - (progress * circumference);
  document.getElementById('progress-circle').style.strokeDashoffset = offset;
}

function vibrate() {
  if (state.vibOn && navigator.vibrate) {
    navigator.vibrate(40);
  }
}

function handleTap() {
  vibrate();
  state.todayTotal++;
  state.grandTotal++;
  state.permanentTotal++; // NEVER decremented, NEVER reset

  if (state.sessionType === 'tasbeeh') {
    state.tasbeehCounter++;
    state.tasbeehIndex = (state.tasbeehCounter - 1) % TASBEEH.length;
    ss('tasbeehCounter', state.tasbeehCounter);
    ss('tasbeehIndex', state.tasbeehIndex);
  } else {
    state.salahCounter++;
    ss('salahCounter', state.salahCounter);
  }

  ss('todayTotal', state.todayTotal);
  ss('grandTotal', state.grandTotal);
  ss('permanentTotal', state.permanentTotal);

  const today = state.lastDate;
  state.daily[today] = state.todayTotal;
  ss('daily', JSON.stringify(state.daily));

  const btn = document.getElementById('tap-btn');
  btn.classList.remove('tapped');
  void btn.offsetWidth;
  btn.classList.add('tapped');

  updateUI();

  if (getCounter() >= state.target) {
    completeSession();
  }
}

function completeSession() {
  const title = document.getElementById('celeb-title');
  const msg   = document.getElementById('celeb-msg');
  const icon  = document.getElementById('celeb-icon');
  const btnNext  = document.getElementById('celeb-btn-next');
  const btnNew   = document.getElementById('celeb-btn-new');

  if (state.sessionType === 'tasbeeh') {
    icon.textContent  = '✨';
    title.textContent = 'أحسنت!';
    msg.textContent   = 'أتممت جلسة التسبيح\nهل تريد الانتقال للصلاة على النبي ﷺ؟';
    btnNext.style.display = 'block';
    btnNew.style.display  = 'none';
  } else {
    icon.textContent  = '🌙';
    title.textContent = 'بارك الله فيك!';
    msg.textContent   = 'أتممت الصلاة على النبي ﷺ\nجزاك الله خيراً وضاعف أجرك';
    btnNext.style.display = 'none';
    btnNew.style.display  = 'block';
  }

  shootConfetti();
  document.getElementById('celebration').classList.add('show');
}

// After tasbeeh complete → reset tasbeeh counter and switch to salah
function startNextType() {
  document.getElementById('celebration').classList.remove('show');
  state.tasbeehCounter = 0;
  state.tasbeehIndex   = 0;
  state.sessionType    = 'salah';
  ss('sessionType', 'salah');
  ss('tasbeehIndex', '0');
  ss('tasbeehCounter', '0');
  updateUI();
}

// After salah complete → reset both, go back to tasbeeh, increment session #
function startNewSession() {
  document.getElementById('celebration').classList.remove('show');
  state.salahCounter   = 0;
  state.tasbeehCounter = 0;
  state.tasbeehIndex   = 0;
  state.sessionType    = 'tasbeeh';
  state.sessionNum++;
  ss('sessionType', 'tasbeeh');
  ss('tasbeehIndex', '0');
  ss('tasbeehCounter', '0');
  ss('salahCounter', '0');
  ss('sessionNum', state.sessionNum);
  updateUI();
}

function closeCelebration() {
  document.getElementById('celebration').classList.remove('show');
}

function resetSession() {
  const typeLabel = state.sessionType === 'salah' ? 'الصلاة على النبي' : 'التسبيح';
  if (!confirm(`هل تريد إعادة تعيين عداد ${typeLabel}؟`)) return;
  if (state.sessionType === 'tasbeeh') {
    state.tasbeehCounter = 0;
    state.tasbeehIndex   = 0;
    ss('tasbeehCounter','0');
    ss('tasbeehIndex','0');
  } else {
    state.salahCounter = 0;
    ss('salahCounter','0');
  }
  updateUI();
}

// ======= CONFETTI =======
function shootConfetti() {
  const colors = ['#d4a017','#f0cc55','#3d9e3d','#8fd98f','#fff'];
  for (let i = 0; i < 30; i++) {
    setTimeout(() => {
      const p = document.createElement('div');
      p.className = 'confetti-particle';
      p.style.left = Math.random()*100 + 'vw';
      p.style.top = '-10px';
      p.style.background = colors[Math.floor(Math.random()*colors.length)];
      p.style.animationDuration = (1.5 + Math.random()) + 's';
      p.style.transform = `rotate(${Math.random()*360}deg)`;
      document.body.appendChild(p);
      setTimeout(() => p.remove(), 2500);
    }, i * 50);
  }
}

// ======= STATS =======
function renderStats() {
  document.getElementById('sh-total').textContent = state.permanentTotal.toLocaleString('ar-SA');
  document.getElementById('sc-today').textContent = state.todayTotal.toLocaleString('ar-SA');

  // Yesterday
  const yd = new Date();
  yd.setDate(yd.getDate()-1);
  const ydStr = yd.toLocaleDateString('ar-SA');
  document.getElementById('sc-yesterday').textContent = (state.daily[ydStr]||0).toLocaleString('ar-SA');

  // This week
  let weekTotal = 0;
  for(let i=0;i<7;i++){
    const d = new Date();
    d.setDate(d.getDate()-i);
    const ds = d.toLocaleDateString('ar-SA');
    weekTotal += (state.daily[ds]||0);
  }
  weekTotal += state.todayTotal;
  document.getElementById('sc-week').textContent = weekTotal.toLocaleString('ar-SA');
  document.getElementById('sc-sessions').textContent = state.sessionNum;

  // Daily history
  const today = state.lastDate;
  const allDays = {...state.daily, [today]: state.todayTotal};
  const sortedDays = Object.entries(allDays)
    .filter(([,v]) => v > 0)
    .sort((a,b) => b[0].localeCompare(a[0]))
    .slice(0,14);

  const maxVal = Math.max(...sortedDays.map(([,v])=>v), 1);
  const container = document.getElementById('daily-history');
  container.innerHTML = '';

  if (sortedDays.length === 0) {
    container.innerHTML = '<div style="text-align:center;color:var(--green-300);padding:20px;font-size:14px">لا توجد إحصائيات بعد</div>';
    return;
  }

  sortedDays.forEach(([date, count]) => {
    const pct = (count/maxVal*100).toFixed(0);
    const row = document.createElement('div');
    row.className = 'day-row';
    row.innerHTML = `
      <div class="dr-date">${date}</div>
      <div class="day-bar-wrap"><div class="day-bar" style="width:${pct}%"></div></div>
      <div class="dr-count">${count.toLocaleString('ar-SA')}</div>
    `;
    container.appendChild(row);
  });
}

function confirmReset() {
  if (confirm('هل تريد مسح إحصائيات اليوم والسجل اليومي؟\n\n⚠️ العداد التراكمي الأبدي لن يُمسح أبداً.')) {
    const saved = state.permanentTotal;
    state.grandTotal     = 0;
    state.todayTotal     = 0;
    state.daily          = {};
    state.tasbeehCounter = 0;
    state.salahCounter   = 0;
    state.tasbeehIndex   = 0;
    state.sessionNum     = 1;
    state.sessionType    = 'tasbeeh';
    state.permanentTotal = saved;
    ['grandTotal','todayTotal','tasbeehCounter','salahCounter','sessionNum','tasbeehIndex']
      .forEach(k => ss(k, '0'));
    ss('daily', '{}');
    ss('sessionType', 'tasbeeh');
    ss('permanentTotal', saved);
    updateUI();
    renderStats();
    if (document.getElementById('home').classList.contains('active')) renderHome();
    alert('تم مسح الإحصائيات. العداد التراكمي الأبدي محفوظ.');
  }
}

// ======= SETTINGS =======
function renderSettings() {
  document.getElementById('count-val').textContent = state.dailyCount;
  document.getElementById('target-val').textContent = state.target;
  document.getElementById('notif-toggle').className = 'toggle' + (state.notifOn?' on':'');
  document.getElementById('vib-toggle').className = 'toggle' + (state.vibOn?' on':'');
  document.getElementById('times-section').style.display = state.notifOn ? '' : 'none';
  renderTimes();
}

function renderTimes() {
  const list = document.getElementById('times-list');
  list.innerHTML = '';
  state.notifTimes.forEach((t, i) => {
    const pill = document.createElement('div');
    pill.className = 'time-pill';
    pill.innerHTML = `
      <input type="time" value="${t}" onchange="updateTime(${i}, this.value)">
      <button class="time-remove" onclick="removeTime(${i})">×</button>
    `;
    list.appendChild(pill);
  });
}

function addTime() {
  state.notifTimes.push('09:00');
  renderTimes();
}
function removeTime(i) {
  state.notifTimes.splice(i,1);
  renderTimes();
}
function updateTime(i,v) { state.notifTimes[i]=v; }

function changeCount(d) {
  state.dailyCount = Math.max(1, Math.min(10, state.dailyCount+d));
  document.getElementById('count-val').textContent = state.dailyCount;
}
function changeTarget(d) {
  state.target = Math.max(10, Math.min(1000, state.target+d));
  document.getElementById('target-val').textContent = state.target;
}
function toggleNotif() {
  state.notifOn = !state.notifOn;
  document.getElementById('notif-toggle').className = 'toggle'+(state.notifOn?' on':'');
  document.getElementById('times-section').style.display = state.notifOn ? '' : 'none';
}
function toggleVib() {
  state.vibOn = !state.vibOn;
  document.getElementById('vib-toggle').className = 'toggle'+(state.vibOn?' on':'');
}

function saveSettings() {
  ss('dailyCount', state.dailyCount);
  ss('target', state.target);
  ss('notifOn', state.notifOn);
  ss('vibOn', state.vibOn);
  ss('notifTimes', JSON.stringify(state.notifTimes));
  vibrate();
  sendTimesToSW();
  if (state.notifOn) scheduleNotifications();
  const btn = document.querySelector('.save-btn');
  btn.textContent = '✅ تم الحفظ!';
  setTimeout(()=>btn.textContent='💾 حفظ الإعدادات', 2000);
}

// ======= SERVICE WORKER + NOTIFICATIONS =======
let swReg = null;

async function initSW() {
  if (!('serviceWorker' in navigator)) return;
  try {
    swReg = await navigator.serviceWorker.register('./sw.js', { scope: './' });
    console.log('SW registered');
    // Listen for messages from SW
    navigator.serviceWorker.addEventListener('message', e => {
      if (e.data && e.data.type === 'GET_TIMES') sendTimesToSW();
    });
    // Send times once SW is ready
    await navigator.serviceWorker.ready;
    sendTimesToSW();
    // Register periodic sync if supported (Chrome Android)
    if (swReg && 'periodicSync' in swReg) {
      try {
        await swReg.periodicSync.register('tasbeeh-check', { minInterval: 60 * 60 * 1000 });
      } catch(e) { /* not supported, that's ok */ }
    }
  } catch(err) {
    console.warn('SW registration failed:', err);
  }
}

function sendTimesToSW() {
  if (!navigator.serviceWorker.controller) return;
  navigator.serviceWorker.controller.postMessage({
    type: 'UPDATE_TIMES',
    times: state.notifTimes,
    enabled: state.notifOn
  });
}

async function requestNotifPermission() {
  if (!('Notification' in window)) return false;
  if (Notification.permission === 'granted') return true;
  const p = await Notification.requestPermission();
  return p === 'granted';
}

async function scheduleNotifications() {
  if (!state.notifOn) return;
  const granted = await requestNotifPermission();
  if (!granted) {
    alert('⚠️ يرجى السماح بالإشعارات من إعدادات المتصفح لكي تصلك التذكيرات');
    return;
  }
  sendTimesToSW();
}

// Test notification (called from settings save)
async function testNotification() {
  const granted = await requestNotifPermission();
  if (!granted) return;
  if (swReg) {
    swReg.showNotification('مسبحتي 📿', {
      body: 'الإشعارات تعمل بنجاح ✅ ستصلك التذكيرات في الأوقات المحددة',
      icon: './icons/icon-192.png',
      vibrate: [200, 100, 200],
      tag: 'tasbeeh-test'
    });
  }
}

// ======= PWA INSTALL PROMPT =======
let deferredInstallPrompt = null;
window.addEventListener('beforeinstallprompt', e => {
  e.preventDefault();
  deferredInstallPrompt = e;
  document.getElementById('install-banner').style.display = 'flex';
});
window.addEventListener('appinstalled', () => {
  document.getElementById('install-banner').style.display = 'none';
  deferredInstallPrompt = null;
});
function installApp() {
  if (!deferredInstallPrompt) return;
  deferredInstallPrompt.prompt();
  deferredInstallPrompt.userChoice.then(() => {
    deferredInstallPrompt = null;
    document.getElementById('install-banner').style.display = 'none';
  });
}
function dismissInstall() {
  document.getElementById('install-banner').style.display = 'none';
}

// ======= INIT =======
setTimeout(async () => {
  document.getElementById('splash').classList.remove('active');
  showScreen('home');
  updateUI();
  await initSW();
  if (state.notifOn) scheduleNotifications();
}, 2200);
</script>
<!-- PWA INSTALL BANNER -->
<div id="install-banner" style="display:none;position:fixed;bottom:90px;left:16px;right:16px;
  background:linear-gradient(135deg,#1a4a1a,#0f2d0f);border:1px solid rgba(212,160,23,0.5);
  border-radius:16px;padding:14px 16px;z-index:50;align-items:center;gap:12px;
  box-shadow:0 4px 20px rgba(0,0,0,0.4);">
  <span style="font-size:24px">📲</span>
  <div style="flex:1">
    <div style="font-size:14px;font-weight:600;color:#f0cc55">ثبّت التطبيق</div>
    <div style="font-size:11px;color:#8fd98f">أضفه للشاشة الرئيسية للإشعارات الكاملة</div>
  </div>
  <button onclick="installApp()" style="background:linear-gradient(135deg,#d4a017,#f0cc55);
    color:#0a1f0a;border:none;border-radius:10px;padding:8px 14px;font-family:Cairo,sans-serif;
    font-size:13px;font-weight:700;cursor:pointer">تثبيت</button>
  <button onclick="dismissInstall()" style="background:transparent;border:none;color:#8fd98f;
    font-size:20px;cursor:pointer;padding:4px">×</button>
</div>

