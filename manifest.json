<script>
// ======= STATE =======
const TASBEEH = [
  { text: 'سبحان الله',    label: '' },
  { text: 'الحمد لله',     label: '' },
  { text: 'لا إله إلا الله', label: '' },
  { text: 'الله أكبر',     label: '' }
];

const SALAH = {
  text: 'اللهم صلِّ وسلِّم وبارك على سيدنا محمد\nوعلى آله وصحبه جميعاً',
  label: ''
};

// Storage key prefix
const SK = 'tasbeeh_';
function ls(k) { try { return localStorage.getItem(SK+k); } catch(e){return null;} }
function ss(k,v) { try { localStorage.setItem(SK+k, v); } catch(e){} }

// Load persisted state
let state = {
  // current session type (which screen the user is in)
  sessionType: ls('sessionType') || 'tasbeeh', // 'tasbeeh' | 'salah'
  // Tasbeeh-specific progress (separately persisted)
  tasbeehIndex: parseInt(ls('tasbeehIndex')||'0'),
  tasbeehCounter: parseInt(ls('tasbeehCounter') || ls('counter') || '0'),
  // Salah-specific progress
  salahCounter: parseInt(ls('salahCounter')||'0'),
  sessionNum: parseInt(ls('sessionNum')||'1'),
  // settings
  dailyCount: parseInt(ls('dailyCount')||'3'),
  target: parseInt(ls('target')||'100'),
  notifOn: ls('notifOn') !== 'false',
  vibOn: ls('vibOn') !== 'false',
  notifTimes: JSON.parse(ls('notifTimes')||'["07:00","13:00","21:00"]'),
  // stats — grandTotal is NEVER reset
  grandTotal: parseInt(ls('grandTotal')||'0'),
  // permanentTotal: cumulative forever, cannot be cleared
  permanentTotal: parseInt(ls('permanentTotal')||'0'),
  todayTotal: parseInt(ls('todayTotal')||'0'),
  lastDate: ls('lastDate') || '',
  daily: JSON.parse(ls('daily')||'{}'),
};

// Make sure permanentTotal is never less than grandTotal (migration safety)
if (state.permanentTotal < state.grandTotal) {
  state.permanentTotal = state.grandTotal;
  ss('permanentTotal', state.permanentTotal);
}

// Check if day changed
function checkDay() {
  const today = new Date().toLocaleDateString('ar-SA');
  if (state.lastDate !== today) {
    // Save yesterday if had activity
    if (state.todayTotal > 0 && state.lastDate) {
      state.daily[state.lastDate] = state.todayTotal;
      ss('daily', JSON.stringify(state.daily));
    }
    state.lastDate = today;
    state.todayTotal = 0;
    state.sessionNum = 1;
    ss('lastDate', today);
    ss('todayTotal','0');
    ss('sessionNum','1');
  }
}
checkDay();

// ════════════════════════════════════════════════════════════════════
// Counter helpers — read/write the right counter for the active session
// ════════════════════════════════════════════════════════════════════
function getCounter() {
  return state.sessionType === 'tasbeeh' ? state.tasbeehCounter : state.salahCounter;
}
function setCounter(n) {
  if (state.sessionType === 'tasbeeh') {
    state.tasbeehCounter = n;
    ss('tasbeehCounter', n);
  } else {
    state.salahCounter = n;
    ss('salahCounter', n);
  }
}

// ════════════════════════════════════════════════════════════════════
// Hijri date — uses Intl.DateTimeFormat with Islamic-Umm al-Qura calendar
// ════════════════════════════════════════════════════════════════════
const HIJRI_MONTHS = [
  'محرم','صفر','ربيع الأول','ربيع الآخر','جمادى الأولى','جمادى الآخرة',
  'رجب','شعبان','رمضان','شوال','ذو القعدة','ذو الحجة'
];
const ARABIC_DAYS = ['الأحد','الاثنين','الثلاثاء','الأربعاء','الخميس','الجمعة','السبت'];
const ARABIC_MONTHS_GREG = [
  'يناير','فبراير','مارس','أبريل','مايو','يونيو',
  'يوليو','أغسطس','سبتمبر','أكتوبر','نوفمبر','ديسمبر'
];

function getHijriDate() {
  try {
    // Use Umm al-Qura Islamic calendar
    const fmt = new Intl.DateTimeFormat('en-u-ca-islamic-umalqura', {
      day: 'numeric', month: 'numeric', year: 'numeric'
    });
    const parts = fmt.formatToParts(new Date());
    let d=1, m=1, y=1446;
    parts.forEach(p => {
      if (p.type === 'day') d = parseInt(p.value);
      if (p.type === 'month') m = parseInt(p.value);
      if (p.type === 'year') y = parseInt(p.value);
    });
    return { day: d, month: m, year: y, monthName: HIJRI_MONTHS[m-1] || HIJRI_MONTHS[0] };
  } catch(e) {
    return { day: 1, month: 1, year: 1446, monthName: HIJRI_MONTHS[0] };
  }
}

// Convert Western digits to Arabic-Indic digits
function toArDigits(n) {
  const ar = ['٠','١','٢','٣','٤','٥','٦','٧','٨','٩'];
  return String(n).replace(/\d/g, d => ar[+d]);
}

// ════════════════════════════════════════════════════════════════════
// Daily Du'a — rotates by day-of-year so each day has a different du'a
// ════════════════════════════════════════════════════════════════════
const DAILY_DUAS = [
  { title: 'دعاء الرزق',
    text: 'اللهم إني أسألك من فضلك ورحمتك، فإنه لا يملكها إلا أنت. اللهم ارزقني رزقاً حلالاً طيباً مباركاً فيه.' },
  { title: 'دعاء الصحة والعافية',
    text: 'اللهم عافني في بدني، اللهم عافني في سمعي، اللهم عافني في بصري، لا إله إلا أنت.' },
  { title: 'دعاء فك الكرب',
    text: 'لا إله إلا الله العظيم الحليم، لا إله إلا الله رب العرش العظيم، لا إله إلا الله رب السماوات ورب الأرض ورب العرش الكريم.' },
  { title: 'دعاء التوبة',
    text: 'اللهم أنت ربي لا إله إلا أنت، خلقتني وأنا عبدك، وأنا على عهدك ووعدك ما استطعت، أعوذ بك من شر ما صنعت.' },
  { title: 'دعاء الوالدين',
